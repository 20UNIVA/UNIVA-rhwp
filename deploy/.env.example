# rhwp-server 환경변수 — 복사하여 .env 로 사용
# bind 주소
RHWP_SERVER_ADDR=0.0.0.0:7710
# sqlite 경로 (작업 중 세션/patch 영속). 디렉터리는 미리 생성해 두세요.
RHWP_SERVER_DB=./rhwp-sessions.db
# studio 정적 자산 경로. 패키지 내에서는 ./studio. 비우면 API 전용(정적 서빙 끔).
RHWP_STUDIO_DIR=./studio
# 외부 minio 저장소 (실제 호스트로 변경)
UPLOAD_URL=http://192.168.0.5:25029/upload
DOWNLOAD_URL=http://192.168.0.5:25029/download/{file_id}
# 로그
RUST_LOG=rhwp_server=info,tower_http=warn
