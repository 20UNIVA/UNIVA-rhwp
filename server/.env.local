# 로컬 PC 테스트용 환경변수 — server crate cwd 기준
# 외부 minio (UPLOAD_URL / DOWNLOAD_URL) 없음 — 외부 파일 업로드/다운로드 비활성.
# 빈문서로 시작 + IR/ops/세션 동작은 모두 가능 (m400 page=1·m500 total_pages 검증 자리).

RHWP_SERVER_ADDR=127.0.0.1:7710
RHWP_SERVER_DB=./rhwp-sessions.db
RHWP_STUDIO_DIR=../rhwp-studio/dist
RUST_LOG=rhwp_server=info,tower_http=warn
